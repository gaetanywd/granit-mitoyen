---
// Contact page (EN) : main content loaded from an editable JSON file. No form.
import Layout from '../../layouts/Layout.astro';
import { contactLinks, CONTACT_EMAIL, PRESS_KIT_URL } from '../../data/contact';
import { t } from '../../i18n/dict';
import content from '../../../content/contact.en.json';

const { meta, hero, intro } = content;
---

<Layout title={meta.title} description={meta.description}>
  <h1 class="font-title text-dark text-3xl font-bold mb-6 title-underline inline-block">
    {hero.title}
  </h1>

  {hero.subtitle && (
    <p class="font-subtitle mb-4 text-dark max-w-xl">
      {hero.subtitle}
    </p>
  )}

  {intro?.text && (
    <p class="font-body mb-6 text-dark max-w-xl">
      {intro.text}
    </p>
  )}

  {PRESS_KIT_URL && PRESS_KIT_URL.startsWith('http') && (
    <div class="mb-6">
      <a
        href={PRESS_KIT_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-4 py-2 rounded-md bg-dark text-cream font-body hover:bg-blue-800 transition-colors"
      >
        {t('en', 'contact.presskit')}
      </a>
    </div>
  )}

  <p class="font-body mb-4 max-w-xl text-dark">
    Email —{' '}
    <a href={`mailto:${CONTACT_EMAIL}`} class="text-brand hover:underline">
      {CONTACT_EMAIL}
    </a>
  </p>

  <ul class="space-y-3 max-w-xl">
    {contactLinks.map((link) => (
      <li>
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand hover:underline"
        >
          {t('en', link.labelKey)}
        </a>
      </li>
    ))}
  </ul>
</Layout>
