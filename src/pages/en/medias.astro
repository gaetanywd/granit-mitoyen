---
// Media page (EN) — main texts loaded from an editable JSON file.
import Layout from '../../layouts/Layout.astro';
import ImageCard from '../../components/ImageCard.astro';
import AlbumStreamingStatus from '../../components/AlbumStreamingStatus.astro';
import content from '../../../content/medias.en.json';

const { meta, hero, sections } = content;

const youtubeWatchUrl = import.meta.env.PUBLIC_FIRE_RAIN_YOUTUBE_URL as string | undefined;

function toYoutubeEmbedUrl(url: string | undefined) {
  if (!url) return undefined;
  try {
    const u = new URL(url);

    // Already an embed URL
    if (u.hostname.includes('youtube.com') && u.pathname.startsWith('/embed/')) return u.toString();

    // youtu.be/<id>
    if (u.hostname === 'youtu.be') {
      const id = u.pathname.replace('/', '').trim();
      if (!id) return undefined;
      return `https://www.youtube.com/embed/${id}`;
    }

    // youtube.com/watch?v=<id>
    const v = u.searchParams.get('v');
    if (v) return `https://www.youtube.com/embed/${v}`;

    return undefined;
  } catch {
    return undefined;
  }
}

const youtubeEmbedUrl = toYoutubeEmbedUrl(youtubeWatchUrl);
---

<Layout title={meta.title} description={meta.description}>
  <h1 class="font-title text-dark text-3xl font-bold mb-6 title-underline inline-block">
    {hero.title}
  </h1>

  {hero.subtitle && (
    <p class="font-subtitle mb-8 text-dark max-w-2xl">
      {hero.subtitle}
    </p>
  )}

  <div class="mb-8">
    <AlbumStreamingStatus
      imageSrc="/images/Granit Mitoyen - Lands Of Killbirgahn cover.jpg"
      imageAlt="Lands Of Killbirgahn – album cover"
      availableTitle="Listen to the album"
      unavailableTitle='Album "Lands of Killbirghan" coming soon!'
    />
  </div>

  <div class="mb-8">
    <div class="aspect-video max-w-4xl mx-auto">
      <iframe
        class="w-full h-full rounded-lg shadow-lg"
        src={youtubeEmbedUrl}
        title="YouTube video player"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen>
      </iframe>
    </div>
  </div>

  <div class="bg-dark text-white py-3 px-4 mt-8 mb-4">
    <h2 class="font-subtitle text-2xl font-semibold">
      {sections.montfort.heading}
    </h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <ImageCard 
      src="/concerts/montfort/Montfort 1.jpg"
      alt="Concert Montfort - Photo 1"
      title="Montfort 1"
    />
    <ImageCard 
      src="/concerts/montfort/Montfort 2.jpg"
      alt="Concert Montfort - Photo 2"
      title="Montfort 2"
    />
    <ImageCard 
      src="/concerts/montfort/Montfort 3.jpg"
      alt="Concert Montfort - Photo 3"
      title="Montfort 3"
    />
  </div>

  <div class="bg-dark text-white py-3 px-4 mt-12 mb-4">
    <h2 class="font-subtitle text-2xl font-semibold">
      {sections.stPeran.heading}
    </h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <ImageCard 
      src="/concerts/st peran/St peran 1.jpg"
      alt="Concert St Peran - Photo 1"
      title="St Peran 1"
    />
    <ImageCard 
      src="/concerts/st peran/St peran 2.jpg"
      alt="Concert St Peran - Photo 2"
      title="St Peran 2"
    />
    <ImageCard 
      src="/concerts/st peran/St peran 5.jpg"
      alt="Concert St Peran - Photo 5"
      title="St Peran 5"
    />
    <ImageCard 
      src="/concerts/st peran/St Peran 6.jpg"
      alt="Concert St Peran - Photo 6"
      title="St Peran 6"
    />
    <ImageCard 
      src="/concerts/st peran/St Peran 7.jpg"
      alt="Concert St Peran - Photo 7"
      title="St Peran 7"
    />
  </div>
</Layout>

