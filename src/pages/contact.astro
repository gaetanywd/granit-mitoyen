---
// Page Contact : contenu principal chargé depuis un JSON éditable.
// Un captcha Cloudflare pourra être ajouté plus tard si besoin.
import Layout from '../layouts/Layout.astro';
import { contactLinks, CONTACT_EMAIL } from '../data/contact';
import content from '../../content/contact.fr.json';

const { meta, hero, intro } = content;
---

<Layout title={meta.title} description={meta.description}>
  <h1 class="text-3xl font-bold mb-6">
    {hero.title}
  </h1>

  {hero.subtitle && (
    <p class="mb-4 text-gray-600 max-w-xl">
      {hero.subtitle}
    </p>
  )}

  {intro?.text && (
    <p class="mb-6 text-gray-700 max-w-xl">
      {intro.text}
    </p>
  )}

  <p class="mb-4 max-w-xl">
    Email —{' '}
    <a href={`mailto:${CONTACT_EMAIL}`} class="text-blue-600 hover:text-blue-800 hover:underline">
      {CONTACT_EMAIL}
    </a>
  </p>

  <ul class="space-y-3 max-w-xl">
    {contactLinks.map((link) => (
      <li>
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-blue-600 hover:text-blue-800 hover:underline"
        >
          {link.type.charAt(0).toUpperCase() + link.type.slice(1)}
        </a>
      </li>
    ))}
  </ul>
</Layout>
