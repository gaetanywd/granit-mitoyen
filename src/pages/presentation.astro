---
// Page Présentation : texte principal tiré d'un fichier JSON éditable.
import Layout from '../layouts/Layout.astro';
import MemberBlock from '../components/MemberBlock.astro';
import { members } from '../data/members';
import content from '../../content/presentation.fr.json';

const { meta, hero, sections } = content;
---

<Layout title={meta.title} description={meta.description}>
  <h1 class="font-title text-dark text-3xl font-bold mb-2 title-underline inline-block">
    {hero.title}
  </h1>
  {hero.subtitle && (
    <p class="font-subtitle text-dark mb-6">
      {hero.subtitle}
    </p>
  )}

  <section class="mb-12">
    <h2 class="font-subtitle text-dark text-2xl font-semibold mb-4 title-underline inline-block">
      {sections.group.heading}
    </h2>
    <p class="font-body text-dark leading-relaxed mb-6 max-w-3xl">
      {sections.group.text}
    </p>
    <img
      src="/images/Granit Mitoyen members horizontal.jpg"
      alt="Granit Mitoyen"
      class="w-full max-w-4xl rounded-lg shadow-md mb-8"
    />
  </section>

  <div class="space-y-0">
    {members.map((member, index) => (
      <MemberBlock
        member={member}
        imageOnLeft={index % 2 === 0}
        locale="fr"
      />
    ))}
  </div>

  <div class="mt-12 flex justify-center">
    <img
      src="/images/Granit Mitoyen members vertical.jpg"
      alt="Granit Mitoyen"
      class="w-full max-w-sm rounded-lg shadow-md"
    />
  </div>
</Layout>
