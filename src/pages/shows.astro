---
// Page Concerts / Shows — liste des concerts passés et données structurées.
import Layout from '../layouts/Layout.astro';
import ShowCard from '../components/ShowCard.astro';
import { shows } from '../data/shows';
import content from '../../content/shows.fr.json';

const { meta, hero, intro } = content;

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://granitmitoyen.com';

// Séparation automatique des concerts selon la date du jour (ISO YYYY-MM-DD).
const todayIso = new Date().toISOString().slice(0, 10);
const upcomingShows = shows.filter((show) => show.dateIso >= todayIso);
const pastShows = shows.filter((show) => show.dateIso < todayIso);

// Données structurées : on ne déclare que les concerts à venir comme événements programmés.
const eventsSchema = upcomingShows.map((show) => ({
  '@context': 'https://schema.org',
  '@type': 'MusicEvent',
  name: `Granit Mitoyen - concert`,
  startDate: show.dateIso,
  // Si on n'a pas l'heure de fin, on expose une fin “same-day” (événement à la journée).
  // Ça évite le warning GSC sans inventer une durée.
  endDate: show.dateIso,
  location: {
    '@type': 'Place',
    name: show.address,
    address: {
      '@type': 'PostalAddress',
      streetAddress: show.address,
      addressRegion: 'Bretagne',
      addressCountry: 'FR',
    },
  },
  performer: {
    '@type': 'MusicGroup',
    name: 'Granit Mitoyen',
  },
  organizer: {
    '@type': 'MusicGroup',
    name: 'Granit Mitoyen',
    url: new URL('/', siteUrl).toString(),
  },
  description: `Concert de Granit Mitoyen à ${show.address} le ${show.dateLabel}.`,
  image: new URL('/images/bandeau.png', siteUrl).toString(),
  ...(show.mainLink
    ? {
        offers: {
          '@type': 'Offer',
          url: show.mainLink,
          availability: 'https://schema.org/InStock',
        },
      }
    : {}),
  eventStatus: 'https://schema.org/EventScheduled',
  url: new URL(Astro.url.pathname, siteUrl).toString(),
}));
---

<Layout title={meta.title} description={meta.description} structuredData={eventsSchema}>
  <h1 class="font-title text-dark text-3xl font-bold mb-6 title-underline inline-block">
    {hero.title}
  </h1>

  <p class="font-body text-dark mb-8 max-w-2xl">
    {intro.text}
  </p>

  <section class="space-y-8 max-w-2xl">
    <div>
      <h2 class="font-subtitle text-dark text-2xl font-semibold mb-4">
        Concerts à venir
      </h2>
      <div class="space-y-4">
        {upcomingShows.length > 0 ? (
          upcomingShows.map((show) => <ShowCard show={show} locale="fr" />)
        ) : (
          <p class="font-body text-dark text-sm italic">
            Aucun concert à venir pour le moment.
          </p>
        )}
      </div>
    </div>

    <div>
      <h2 class="font-subtitle text-dark text-2xl font-semibold mb-4">
        Concerts passés
      </h2>
      <div class="space-y-4">
        {pastShows.length > 0 ? (
          pastShows.map((show) => <ShowCard show={show} locale="fr" />)
        ) : (
          <p class="font-body text-dark text-sm italic">
            Aucun concert passé pour le moment.
          </p>
        )}
      </div>
    </div>
  </section>
</Layout>
