---
// Page Médias — textes principaux chargés depuis un JSON éditable.
import Layout from '../layouts/Layout.astro';
import ImageCard from '../components/ImageCard.astro';
import content from '../../content/medias.fr.json';

const { meta, hero, sections } = content;
---

<Layout title={meta.title} description={meta.description}>
  <h1 class="text-3xl font-bold mb-6">
    {hero.title}
  </h1>

  {hero.subtitle && (
    <p class="mb-8 text-gray-600 max-w-2xl">
      {hero.subtitle}
    </p>
  )}

  <div class="mb-8">
    <div class="aspect-video max-w-4xl mx-auto">
      <iframe 
        class="w-full h-full rounded-lg shadow-lg"
        src="https://www.youtube.com/embed/yTAwnxUROY8?si=UkJRPpYVgxgJ5QHP" 
        title="YouTube video player" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        referrerpolicy="strict-origin-when-cross-origin" 
        allowfullscreen>
      </iframe>
    </div>
  </div>

  <h2 class="text-2xl font-semibold mb-4 mt-8">
    {sections.montfort.heading}
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <ImageCard 
      src="/concerts/montfort/Montfort 1.jpg"
      alt="Concert Montfort - Photo 1"
      title="Montfort 1"
    />
    <ImageCard 
      src="/concerts/montfort/Montfort 2.jpg"
      alt="Concert Montfort - Photo 2"
      title="Montfort 2"
    />
    <ImageCard 
      src="/concerts/montfort/Montfort 3.jpg"
      alt="Concert Montfort - Photo 3"
      title="Montfort 3"
    />
  </div>

  <h2 class="text-2xl font-semibold mb-4 mt-12">
    {sections.stPeran.heading}
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <ImageCard 
      src="/concerts/st peran/St peran 1.jpg"
      alt="Concert St Peran - Photo 1"
      title="St Peran 1"
    />
    <ImageCard 
      src="/concerts/st peran/St peran 2.jpg"
      alt="Concert St Peran - Photo 2"
      title="St Peran 2"
    />
    <ImageCard 
      src="/concerts/st peran/St peran 5.jpg"
      alt="Concert St Peran - Photo 5"
      title="St Peran 5"
    />
    <ImageCard 
      src="/concerts/st peran/St Peran 6.jpg"
      alt="Concert St Peran - Photo 6"
      title="St Peran 6"
    />
    <ImageCard 
      src="/concerts/st peran/St Peran 7.jpg"
      alt="Concert St Peran - Photo 7"
      title="St Peran 7"
    />
  </div>
</Layout>

