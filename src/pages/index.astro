---
// Page d'accueil FR
// Le texte affiché vient d'un fichier JSON de contenu à la racine du projet.
import Layout from '../layouts/Layout.astro';
import home from '../../content/home.fr.json';
import { CONTACT_EMAIL } from '../data/contact';

const { meta, hero, sections } = home;
---

<Layout title={meta.title} description={meta.description}>
	<div class="text-center mb-8">
		<h1 class="font-title text-dark text-3xl font-bold title-underline inline-block">
			{hero.title}
		</h1>
	</div>

	<div class="max-w-2xl mx-auto text-center space-y-4">
		<div class="font-subtitle text-xl text-dark">
			{hero.subtitle}
		</div>
	</div>

	<section class="max-w-3xl mx-auto mt-10 space-y-8 text-left">
		<div>
			<h2 class="font-subtitle text-dark text-2xl font-semibold mb-3 title-underline inline-block">
				{sections.about.title}
			</h2>
			<p class="font-body text-dark">
				{sections.about.text}
			</p>
		</div>

		<div class="max-w-5xl mx-auto mt-10">
			<img src="/images/Granit Mitoyen members horizontal.jpg" alt="Groupe JM" class="w-full h-auto" />
		</div>

		<div>
			<h2 class="font-subtitle text-dark text-2xl font-semibold mb-3 title-underline inline-block">
				{sections.albumHighlight.title}
			</h2>
			<p class="font-body text-dark">
				{sections.albumHighlight.text}
			</p>
		</div>

		<div>
			<h2 class="font-subtitle text-dark text-2xl font-semibold mb-3 title-underline inline-block">
				{sections.showsHighlight.title}
			</h2>
			<p class="font-body text-dark">
				{sections.showsHighlight.text}
			</p>
		</div>
	</section>
</Layout>
