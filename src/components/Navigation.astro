---
import { t, type Locale } from '../i18n/dict';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentPath = Astro.url.pathname;

function buildLocalePath(targetLocale: Locale): string {
  let basePath = currentPath;
  if (basePath !== '/' && basePath.endsWith('/')) {
    basePath = basePath.slice(0, -1);
  }

  const isEnglishPath = basePath === '/en' || basePath.startsWith('/en/');

  if (targetLocale === 'fr') {
    if (isEnglishPath) {
      const withoutEn = basePath.replace(/^\/en/, '') || '/';
      return withoutEn;
    }
    return basePath || '/';
  }

  if (isEnglishPath) {
    return basePath || '/en';
  }

  if (basePath === '/') {
    return '/en/';
  }

  return `/en${basePath}`;
}

const frUrl = buildLocalePath('fr');
const enUrl = buildLocalePath('en');

const isHome =
  currentPath === '/' ||
  currentPath === '/en' ||
  currentPath === '/en/';

const isMedias =
  currentPath === '/medias' ||
  currentPath === '/medias/' ||
  currentPath === '/en/medias' ||
  currentPath === '/en/medias/';

const isShows =
  currentPath === '/shows' ||
  currentPath === '/shows/' ||
  currentPath === '/en/shows' ||
  currentPath === '/en/shows/';

const isPresentation =
  currentPath === '/presentation' ||
  currentPath === '/presentation/' ||
  currentPath === '/en/presentation' ||
  currentPath === '/en/presentation/';

const isDiscography =
  currentPath === '/discographie' ||
  currentPath === '/discographie/' ||
  currentPath === '/en/discography' ||
  currentPath === '/en/discography/';

const isContact =
  currentPath === '/contact' ||
  currentPath === '/contact/' ||
  currentPath === '/en/contact' ||
  currentPath === '/en/contact/';

const shopUrl = import.meta.env.PUBLIC_BIGCARTEL_URL as string | undefined;
const hasShop = Boolean(shopUrl?.startsWith('http'));
---

<div>
  <a href="/">
    <img src="/images/LOGO_2026_Black2.png" alt="Granit Mitoyen" class="h-60 m-auto my-5" />
  </a>
</div>

<nav class="bg-dark text-white p-4 sticky top-0 z-10">
  <div class="container mx-auto space-y-3">
    <div class="flex items-center justify-between gap-3">
      <div></div>

      <div class="flex items-center gap-3">
        <button
          type="button"
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-white/40 text-sm sm:hidden"
          data-menu-toggle
          aria-expanded="false"
          aria-controls="main-nav-menu"
        >
          Menu
        </button>

        <div class="hidden sm:flex gap-6">
          <a
            href="/"
            class:list={[
              "hover:text-blue-300 transition-colors",
              isHome && "text-blue-400 font-bold",
            ]}
          >
            {t(locale, 'nav.home')}
          </a>
          <a
            href="/medias"
            class:list={[
              "hover:text-blue-300 transition-colors",
              isMedias && "text-blue-400 font-bold",
            ]}
          >
            {t(locale, 'nav.medias')}
          </a>
          <a
            href="/shows"
            class:list={[
              "hover:text-blue-300 transition-colors",
              isShows && "text-blue-400 font-bold",
            ]}
          >
            {t(locale, 'nav.shows')}
          </a>
          <!-- <a
            href="/presentation"
            class:list={[
              "hover:text-blue-300 transition-colors",
              isPresentation && "text-blue-400 font-bold",
            ]}
          >
            {t(locale, 'nav.presentation')}
          </a> -->
          <a
            href="/discographie"
            class:list={[
              "hover:text-blue-300 transition-colors",
              isDiscography && "text-blue-400 font-bold",
            ]}
          >
            {t(locale, 'nav.discography')}
          </a>
          {hasShop && (
            <a
              href={shopUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-blue-300 transition-colors inline-flex items-center gap-1.5"
            >
              <span>{t(locale, 'nav.shop')}</span>
              <i class="fa-solid fa-arrow-up-right-from-square text-xs" aria-hidden="true"></i>
            </a>
          )}
          <a
            href="/contact"
            class:list={[
              "hover:text-blue-300 transition-colors",
              isContact && "text-blue-400 font-bold",
            ]}
          >
            {t(locale, 'nav.contact')}
          </a>
        </div>
      </div>

      <div class="flex items-center gap-2 justify-start sm:justify-end">
        <a
          href={frUrl}
          aria-label="Français"
          class:list={[
            "transition-opacity inline-block",
            locale === 'fr' ? "opacity-100 ring-2 ring-blue-400 rounded" : "opacity-70 hover:opacity-100",
          ]}
        >
          <img src="/interface/fr_flag.png" alt="" width="24" height="18" class="block rounded-sm" />
        </a>
        <span class="text-gray-500 w-px h-4 bg-gray-500" aria-hidden="true"></span>
        <a
          href={enUrl}
          aria-label="English"
          class:list={[
            "transition-opacity inline-block",
            locale === 'en' ? "opacity-100 ring-2 ring-blue-400 rounded" : "opacity-70 hover:opacity-100",
          ]}
        >
          <img src="/interface/en_flag.png" alt="" width="24" height="18" class="block rounded-sm" />
        </a>
      </div>
    </div>

    <div
      id="main-nav-menu"
      data-menu
      class="flex flex-col gap-2 border-t border-white/20 pt-3 sm:hidden hidden"
    >
      <a
        href="/"
        class:list={[
          "hover:text-blue-300 transition-colors",
          isHome && "text-blue-400 font-bold",
        ]}
      >
        {t(locale, 'nav.home')}
      </a>
      <a
        href="/medias"
        class:list={[
          "hover:text-blue-300 transition-colors",
          isMedias && "text-blue-400 font-bold",
        ]}
      >
        {t(locale, 'nav.medias')}
      </a>
      <a
        href="/shows"
        class:list={[
          "hover:text-blue-300 transition-colors",
          isShows && "text-blue-400 font-bold",
        ]}
      >
        {t(locale, 'nav.shows')}
      </a>
      <a
        href="/presentation"
        class:list={[
          "hover:text-blue-300 transition-colors",
          isPresentation && "text-blue-400 font-bold",
        ]}
      >
        {t(locale, 'nav.presentation')}
      </a>
      <a
        href="/discographie"
        class:list={[
          "hover:text-blue-300 transition-colors",
          isDiscography && "text-blue-400 font-bold",
        ]}
      >
        {t(locale, 'nav.discography')}
      </a>
      {hasShop && (
        <a
          href={shopUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-blue-300 transition-colors inline-flex items-center gap-1.5"
        >
          <span>{t(locale, 'nav.shop')}</span>
          <i class="fa-solid fa-arrow-up-right-from-square text-xs" aria-hidden="true"></i>
        </a>
      )}
      <a
        href="/contact"
        class:list={[
          "hover:text-blue-300 transition-colors",
          isContact && "text-blue-400 font-bold",
        ]}
      >
        {t(locale, 'nav.contact')}
      </a>
    </div>
  </div>
</nav>

<script>
  // Petit script pour ouvrir / fermer le menu mobile sans framework.
  if (typeof window !== 'undefined') {
    window.addEventListener('DOMContentLoaded', () => {
      const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
      const menu = document.querySelector<HTMLElement>('[data-menu]');

      if (!toggle || !menu) return;

      toggle.addEventListener('click', () => {
        const isHidden = menu.classList.toggle('hidden');
        toggle.setAttribute('aria-expanded', (!isHidden).toString());
      });
    });
  }
</script>
